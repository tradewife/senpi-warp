# waifu environment configuration
# Copy this file to .env and fill in your values

# Required
SENPI_AUTH_TOKEN=""     # Senpi MCP authentication token (get from senpi.ai)
GITHUB_TOKEN=""         # GitHub fine-grained token with repo read/write

# Optional (defaults shown)
# SENPI_WAIFU_DIR=""    # Project root (auto-detected)
# GITHUB_REPO="tradewife/senpi-waifu"

# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""

# Railway CLI (optional, for debug commands)
# RAILWAY_TOKEN=""

# mcporter binary (optional)
# MCPORTER_CMD="mcporter"
